@model Producto

@{
    ViewData["Title"] = "Eliminar producto";
}

<h1 class="h3 mb-3"><i class="bi bi-trash me-2"></i>Eliminar producto</h1>

<div class="card">
    <div class="card-body p-4">
        <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-1"></i>¿Está seguro que desea eliminar este producto?</div>
        <div class="row">
            <div class="col-md-4">
                <img src="@Model.ImagenUrl" class="img-fluid rounded" alt="@Model.Nombre" />
            </div>
            <div class="col-md-8">
                <dl class="row">
                    <dt class="col-sm-3">Nombre</dt>
                    <dd class="col-sm-9">@Model.Nombre</dd>
                    <dt class="col-sm-3">Categoría</dt>
                    <dd class="col-sm-9">@Model.Categoria?.Nombre</dd>
                    <dt class="col-sm-3">Precio</dt>
                    <dd class="col-sm-9">@Model.Precio.ToString("C")</dd>
                </dl>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Eliminar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i>Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>
