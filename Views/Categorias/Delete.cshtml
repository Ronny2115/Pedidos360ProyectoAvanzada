@model Categoria

@{
    ViewData["Title"] = "Eliminar categoría";
}

<h1 class="h3 mb-3"><i class="bi bi-trash me-2"></i>Eliminar categoría</h1>

<div class="card" style="max-width: 480px;">
    <div class="card-body p-4">
        <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-1"></i>¿Está seguro que desea eliminar esta categoría?</div>
        <dl class="row mb-0">
            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Eliminar</button>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i>Cancelar</a>
        </form>
    </div>
</div>
