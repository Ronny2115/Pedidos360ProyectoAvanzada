@model Pedido

@{
    ViewData["Title"] = "Detalle de pedido";
}

<h1 class="h3 mb-3"><i class="bi bi-receipt me-2" aria-hidden="true"></i>Pedido #@Model.Id</h1>

<partial name="_Alertas" />

<div class="card mb-4">
    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-2"><i class="bi bi-person me-1" aria-hidden="true"></i>Cliente</dt>
            <dd class="col-sm-10">@Model.Cliente?.Nombre (@Model.Cliente?.Cedula)</dd>
            <dt class="col-sm-2"><i class="bi bi-person-badge me-1" aria-hidden="true"></i>Usuario</dt>
            <dd class="col-sm-10">@Model.Usuario?.Email</dd>
            <dt class="col-sm-2"><i class="bi bi-calendar-event me-1" aria-hidden="true"></i>Fecha</dt>
            <dd class="col-sm-10">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</dd>
            <dt class="col-sm-2">Estado</dt>
            <dd class="col-sm-10">
                <span class="badge bg-success-subtle text-success-emphasis"><i class="bi bi-check-circle me-1" aria-hidden="true"></i>@Model.Estado</span>
            </dd>
        </dl>
    </div>
</div>

<div class="table-responsive mb-4">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Producto</th>
                <th class="text-end">Cantidad</th>
                <th class="text-end">Precio unit.</th>
                <th class="text-end">Descuento</th>
                <th class="text-end">Impuesto</th>
                <th class="text-end">Total linea</th>
            </tr>
        </thead>
        <tbody>
@foreach (var detalle in Model.Detalles)
{
            <tr>
                <td><i class="bi bi-cookie text-body-secondary me-2" aria-hidden="true"></i>@detalle.Producto?.Nombre</td>
                <td class="text-end text-num">@detalle.Cantidad</td>
                <td class="text-end text-num">@detalle.PrecioUnit.ToString("C")</td>
                <td class="text-end text-num">@detalle.Descuento%</td>
                <td class="text-end text-num">@detalle.ImpuestoPorc%</td>
                <td class="fw-semibold text-end text-num">@detalle.TotalLinea.ToString("C")</td>
            </tr>
}
        </tbody>
    </table>
</div>

<div class="row justify-content-end">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <span>Subtotal</span>
                    <span>@Model.Subtotal.ToString("C")</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Impuestos</span>
                    <span>@Model.Impuestos.ToString("C")</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Total</span>
                    <span>@Model.Total.ToString("C")</span>
                </div>
            </div>
        </div>
    </div>
</div>

<a asp-action="Index" class="btn btn-outline-secondary mt-3"><i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Volver</a>
