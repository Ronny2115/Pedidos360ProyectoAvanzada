@model Pedido

@{
    ViewData["Title"] = "Detalle de pedido";
}

<h1>Pedido #@Model.Id</h1>

@if (TempData["Success"] is not null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<dl class="row">
    <dt class="col-sm-2">Cliente</dt>
    <dd class="col-sm-10">@Model.Cliente?.Nombre (@Model.Cliente?.Cedula)</dd>
    <dt class="col-sm-2">Usuario</dt>
    <dd class="col-sm-10">@Model.Usuario?.Email</dd>
    <dt class="col-sm-2">Fecha</dt>
    <dd class="col-sm-10">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</dd>
    <dt class="col-sm-2">Estado</dt>
    <dd class="col-sm-10">@Model.Estado</dd>
</dl>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Cantidad</th>
            <th>Precio unit.</th>
            <th>Descuento</th>
            <th>Impuesto</th>
            <th>Total línea</th>
        </tr>
    </thead>
    <tbody>
@foreach (var detalle in Model.Detalles)
{
        <tr>
            <td>@detalle.Producto?.Nombre</td>
            <td>@detalle.Cantidad</td>
            <td>@detalle.PrecioUnit.ToString("C")</td>
            <td>@detalle.Descuento%</td>
            <td>@detalle.ImpuestoPorc%</td>
            <td>@detalle.TotalLinea.ToString("C")</td>
        </tr>
}
    </tbody>
</table>

<div class="row justify-content-end">
    <div class="col-md-4">
        <table class="table">
            <tr>
                <th>Subtotal</th>
                <td class="text-end">@Model.Subtotal.ToString("C")</td>
            </tr>
            <tr>
                <th>Impuestos</th>
                <td class="text-end">@Model.Impuestos.ToString("C")</td>
            </tr>
            <tr>
                <th>Total</th>
                <td class="text-end fw-bold">@Model.Total.ToString("C")</td>
            </tr>
        </table>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary">Volver</a>
