@model IEnumerable<Categoria>

@{
    ViewData["Title"] = "Categorias";
}

<div class="page-header mb-3">
    <h1 class="h3 mb-0"><i class="bi bi-tags me-2" aria-hidden="true"></i>Categorias</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1" aria-hidden="true"></i>Nueva categoria</a>
</div>

<partial name="_Alertas" />

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Nombre</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
@if (!Model.Any())
{
            <tr>
                <td colspan="2" class="p360-vacio">
                    <i class="bi bi-tags" aria-hidden="true"></i>
                    No se encontraron categorias.
                    <a asp-action="Create">Crear la primera categoria</a>
                </td>
            </tr>
}
@foreach (var item in Model)
{
            <tr>
                <td><i class="bi bi-tag text-body-secondary me-2" aria-hidden="true"></i>@item.Nombre</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Ver" aria-label="Ver categoria @item.Nombre"><i class="bi bi-eye" aria-hidden="true"></i></a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Editar" aria-label="Editar categoria @item.Nombre"><i class="bi bi-pencil" aria-hidden="true"></i></a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Eliminar" aria-label="Eliminar categoria @item.Nombre"><i class="bi bi-trash" aria-hidden="true"></i></a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
