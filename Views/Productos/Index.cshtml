@model ProductoIndexViewModel

@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="bi bi-cake2 me-2"></i>Productos</h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Nuevo producto</a>
    }
</div>

@if (TempData["Success"] is not null)
{
    <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i>@TempData["Success"]</div>
}
@if (TempData["Error"] is not null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]</div>
}

<form method="get" asp-action="Index" class="row g-2 mb-4">
    <div class="col-md-4">
        <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input type="text" name="nombre" value="@Model.Nombre" class="form-control" placeholder="Buscar por nombre" />
        </div>
    </div>
    <div class="col-md-4">
        <select name="categoriaId" class="form-select">
            <option value="">Todas las categorías</option>
            @foreach (var categoria in Model.Categorias)
            {
                <option value="@categoria.Id" selected="@(Model.CategoriaId == categoria.Id)">@categoria.Nombre</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-funnel me-1"></i>Filtrar</button>
    </div>
    <div class="col-md-2">
        <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="bi bi-x-lg me-1"></i>Limpiar</a>
    </div>
</form>

<div class="row row-cols-1 row-cols-md-3 g-3">
@foreach (var producto in Model.Productos)
{
        <div class="col">
            <div class="card producto-card h-100">
                <img src="@producto.ImagenUrl" class="card-img-top" alt="@producto.Nombre" style="height:160px;object-fit:cover;" />
                <div class="card-body">
                    <h5 class="card-title">@producto.Nombre</h5>
                    <p class="card-text mb-1"><i class="bi bi-tag text-body-secondary me-1"></i>@producto.Categoria?.Nombre</p>
                    <p class="card-text mb-1"><i class="bi bi-currency-dollar text-body-secondary me-1"></i>@producto.Precio.ToString("C")</p>
                    <p class="card-text mb-1"><i class="bi bi-box-seam text-body-secondary me-1"></i>Stock: @producto.Stock</p>
                    @if (!producto.Activo)
                    {
                        <span class="badge bg-secondary"><i class="bi bi-slash-circle me-1"></i>Inactivo</span>
                    }
                </div>
                <div class="card-footer d-flex justify-content-between">
                    <a asp-action="Details" asp-route-id="@producto.Id" class="btn btn-sm btn-outline-secondary" title="Ver"><i class="bi bi-eye"></i></a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@producto.Id" class="btn btn-sm btn-outline-primary" title="Editar"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@producto.Id" class="btn btn-sm btn-outline-danger" title="Eliminar"><i class="bi bi-trash"></i></a>
                    }
                </div>
            </div>
        </div>
}
</div>

@if (Model.TotalPaginas > 1)
{
    <nav class="mt-4">
        <ul class="pagination">
            @for (var i = 1; i <= Model.TotalPaginas; i++)
            {
                <li class="page-item @(i == Model.Pagina ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-nombre="@Model.Nombre" asp-route-categoriaId="@Model.CategoriaId">@i</a>
                </li>
            }
        </ul>
    </nav>
}
