@model Cliente

@{
    ViewData["Title"] = "Eliminar cliente";
}

<h1>Eliminar cliente</h1>

<div class="alert alert-warning">¿Está seguro que desea eliminar este cliente?</div>

<dl class="row">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Nombre</dd>
    <dt class="col-sm-2">Cédula</dt>
    <dd class="col-sm-10">@Model.Cedula</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
