@model Categoria

@{
    ViewData["Title"] = "Eliminar categoria";
}

<h1 class="h3 mb-3"><i class="bi bi-trash me-2" aria-hidden="true"></i>Eliminar categoria</h1>

<div class="card card-detalle">
    <div class="card-body p-4">
        <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-1" aria-hidden="true"></i>¿Esta seguro que desea eliminar esta categoria?</div>
        <dl class="row mb-0">
            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1" aria-hidden="true"></i>Eliminar</button>
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1" aria-hidden="true"></i>Cancelar</a>
        </form>
    </div>
</div>
