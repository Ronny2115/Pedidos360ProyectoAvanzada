@model ProductoIndexViewModel

@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Productos</h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">Nuevo producto</a>
    }
</div>

@if (TempData["Success"] is not null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] is not null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form method="get" asp-action="Index" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="nombre" value="@Model.Nombre" class="form-control" placeholder="Buscar por nombre" />
    </div>
    <div class="col-md-4">
        <select name="categoriaId" class="form-select">
            <option value="">Todas las categorías</option>
            @foreach (var categoria in Model.Categorias)
            {
                <option value="@categoria.Id" selected="@(Model.CategoriaId == categoria.Id)">@categoria.Nombre</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Filtrar</button>
    </div>
    <div class="col-md-2">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
    </div>
</form>

<div class="row row-cols-1 row-cols-md-3 g-3">
@foreach (var producto in Model.Productos)
{
        <div class="col">
            <div class="card h-100">
                <img src="@producto.ImagenUrl" class="card-img-top" alt="@producto.Nombre" style="height:160px;object-fit:cover;" />
                <div class="card-body">
                    <h5 class="card-title">@producto.Nombre</h5>
                    <p class="card-text mb-1">@producto.Categoria?.Nombre</p>
                    <p class="card-text mb-1">Precio: @producto.Precio.ToString("C")</p>
                    <p class="card-text mb-1">Stock: @producto.Stock</p>
                    @if (!producto.Activo)
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </div>
                <div class="card-footer d-flex justify-content-between">
                    <a asp-action="Details" asp-route-id="@producto.Id" class="btn btn-sm btn-outline-secondary">Ver</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@producto.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                        <a asp-action="Delete" asp-route-id="@producto.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    }
                </div>
            </div>
        </div>
}
</div>

@if (Model.TotalPaginas > 1)
{
    <nav class="mt-3">
        <ul class="pagination">
            @for (var i = 1; i <= Model.TotalPaginas; i++)
            {
                <li class="page-item @(i == Model.Pagina ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-nombre="@Model.Nombre" asp-route-categoriaId="@Model.CategoriaId">@i</a>
                </li>
            }
        </ul>
    </nav>
}
