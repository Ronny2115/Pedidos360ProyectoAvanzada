@model IEnumerable<Pedido>

@{
    ViewData["Title"] = "Pedidos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Pedidos</h1>
    @if (User.IsInRole("Admin") || User.IsInRole("Ventas"))
    {
        <a asp-action="Create" class="btn btn-primary">Nuevo pedido</a>
    }
</div>

@if (TempData["Success"] is not null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Id</th>
            <th>Cliente</th>
            <th>Usuario</th>
            <th>Fecha</th>
            <th>Total</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Id</td>
            <td>@item.Cliente?.Nombre</td>
            <td>@item.Usuario?.Email</td>
            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
            <td>@item.Total.ToString("C")</td>
            <td>@item.Estado</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Ver</a>
            </td>
        </tr>
}
    </tbody>
</table>
