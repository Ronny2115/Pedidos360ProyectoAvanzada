@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-4">
    <div class="display-1 mb-2 text-body-secondary"><i class="bi bi-cake2"></i></div>
    <h1 class="text-danger">Ocurrio un error</h1>
    <p class="text-muted">Se produjo un error al procesar tu solicitud.</p>
</div>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<div class="card">
    <div class="card-body p-4">
        <h3 class="h5"><i class="bi bi-code-slash me-1"></i>Modo desarrollo</h3>
        <p>
            Cambiar al entorno <strong>Development</strong> mostrara informacion mas detallada sobre el error ocurrido.
        </p>
        <p class="mb-0">
            <strong>El entorno Development no debe habilitarse en aplicaciones desplegadas.</strong>
            Puede exponer informacion sensible de las excepciones a los usuarios finales.
            Para depuracion local, habilita el entorno <strong>Development</strong> configurando la variable de entorno <strong>ASPNETCORE_ENVIRONMENT</strong> en <strong>Development</strong> y reinicia la aplicacion.
        </p>
    </div>
</div>
