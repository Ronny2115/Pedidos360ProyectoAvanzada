@model ProductoEditViewModel

@{
    ViewData["Title"] = "Editar producto";
}

<h1>Editar producto</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImagenUrlActual" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CategoriaId" class="form-label"></label>
                <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.Categorias">
                </select>
                <span asp-validation-for="CategoriaId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Precio" class="form-label"></label>
                <input asp-for="Precio" class="form-control" />
                <span asp-validation-for="Precio" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ImpuestoPorc" class="form-label"></label>
                <input asp-for="ImpuestoPorc" class="form-control" />
                <span asp-validation-for="ImpuestoPorc" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Stock" class="form-label"></label>
                <input asp-for="Stock" class="form-control" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="Activo" class="form-check-input" />
                <label asp-for="Activo" class="form-check-label"></label>
            </div>
            <div class="mb-3">
                <label class="form-label">Imagen actual</label><br />
                <img src="@Model.ImagenUrlActual" style="max-height:100px;" class="mb-2 rounded" alt="Imagen actual" /><br />
                <label asp-for="Imagen" class="form-label">Reemplazar imagen (opcional)</label>
                <input asp-for="Imagen" type="file" class="form-control" accept="image/*" />
                <span asp-validation-for="Imagen" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Guardar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
