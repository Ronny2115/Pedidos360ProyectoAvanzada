@model IEnumerable<Producto>

@{
    ViewData["Title"] = "Inventario";
}

<h1 class="h3 mb-3"><i class="bi bi-box-seam me-2" aria-hidden="true"></i>Inventario</h1>

<partial name="_Alertas" />

<form method="get" asp-action="Index" class="row g-2 mb-3">
    <div class="col-md-4">
        <label for="busquedaInventario" class="visually-hidden">Buscar producto por nombre</label>
        <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-search" aria-hidden="true"></i></span>
            <input type="search" id="busquedaInventario" name="nombre" value="@ViewBag.Nombre" class="form-control" placeholder="Buscar por nombre…" autocomplete="off" />
        </div>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Buscar</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Categoria</th>
                <th>Stock actual</th>
                <th>Ajustar stock</th>
            </tr>
        </thead>
        <tbody>
@if (!Model.Any())
{
            <tr>
                <td colspan="4" class="p360-vacio">
                    <i class="bi bi-box-seam" aria-hidden="true"></i>
                    No se encontraron productos.
                </td>
            </tr>
}
@foreach (var producto in Model)
{
            <tr>
                <td><i class="bi bi-cake2 text-body-secondary me-2" aria-hidden="true"></i>@producto.Nombre</td>
                <td><i class="bi bi-tag text-body-secondary me-2" aria-hidden="true"></i>@producto.Categoria?.Nombre</td>
                <td>
                    @if (producto.Stock <= 10)
                    {
                        <span class="badge bg-danger rounded-pill">@producto.Stock</span>
                    }
                    else
                    {
                        <span class="badge bg-success-subtle text-success-emphasis rounded-pill">@producto.Stock</span>
                    }
                </td>
                <td>
                    <form asp-action="AjustarStock" method="post" class="d-flex gap-2 flex-wrap align-items-center">
                        <input type="hidden" name="productoId" value="@producto.Id" />
                        <input type="hidden" name="nombre" value="@ViewBag.Nombre" />
                        <input type="number" name="nuevoStock" min="0" value="@producto.Stock" class="form-control form-control-sm text-num" style="width:100px;" aria-label="Nuevo stock de @producto.Nombre" />
                        <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-arrow-repeat me-1" aria-hidden="true"></i>Actualizar</button>
                    </form>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
